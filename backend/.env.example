# LumenAI environment example

# Runtime mode: development, test, or production
LUMENAI_ENV=development

# Database
DATABASE_URL=postgresql+psycopg2://lumen:lumen@db:5432/lumenai

# Queue / Redis
REDIS_URL=redis://redis:6379/0
QUEUE_BACKEND=rq

# Result handling
RESULT_MODE=advanced

# Security
SECRET_KEY=replace-with-strong-random-secret-at-least-32-characters
JWT_SECRET_KEY=replace-with-different-strong-random-secret
LUMENAI_JWT_SECRET=replace-with-different-strong-random-secret

# Data paths
LUMENAI_DATA_DIR=/data

# Optional non-local object storage. If S3_ENDPOINT points outside local/minio,
# production startup requires S3_ACCESS_KEY, S3_SECRET_KEY, and S3_BUCKET.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Optional model path
LUMENAI_MODEL_PATH=

LUMENAI_LABEL_MAP=backend/config/label_map.example.json

LUMENAI_REPORT_ORG=LumenAI
LUMENAI_REPORT_SUBTITLE=AI Surgical Instrument Inspection Report
LUMENAI_REPORT_WEBSITE=www.lumenai.health
LUMENAI_REPORT_CONTACT=info@lumenai.health
LUMENAI_REPORT_SEGMENT=Healthcare SPD / Vendor QA

# Alert hooks
LUMENAI_ALERTS_ENABLED=false

# Slack / Teams incoming webhooks
LUMENAI_SLACK_WEBHOOK_URL=
LUMENAI_TEAMS_WEBHOOK_URL=

# SMTP email alerting
LUMENAI_SMTP_HOST=
LUMENAI_SMTP_PORT=587
LUMENAI_SMTP_USERNAME=
LUMENAI_SMTP_PASSWORD=
LUMENAI_SMTP_FROM=lumenai-alerts@example.com
LUMENAI_ALERT_EMAIL_TO=

# Channel rollout switches
LUMENAI_SLACK_ENABLED=false
LUMENAI_TEAMS_ENABLED=false
LUMENAI_EMAIL_ENABLED=false

# Channel rollout switches
LUMENAI_SLACK_ENABLED=false
LUMENAI_TEAMS_ENABLED=false
LUMENAI_EMAIL_ENABLED=false

LUMENAI_DIGEST_AUTOMATION_ENABLED=true
LUMENAI_DIGEST_AUTOMATION_CRON=0 7 * * MON
LUMENAI_DIGEST_AUTOMATION_CHANNEL=slack,email
LUMENAI_EXECUTIVE_EMAILS=leader1@domain.com,leader2@domain.com
LUMENAI_EXECUTIVE_SLACK_CHANNEL=#spd-leadership
LUMENAI_DIGEST_AUTOMATION_WINDOW_DAYS=7
LUMENAI_DEFAULT_EXECUTIVE_ROLE_SCOPE=executive
LUMENAI_EVIDENCE_SIGNING_ENABLED=true
LUMENAI_EVIDENCE_SIGNING_SECRET=replace-with-long-random-secret-at-least-32-characters
LUMENAI_RETENTION_ENFORCEMENT_ENABLED=true
LUMENAI_RETENTION_ENFORCEMENT_CRON=0 2 * * *
LUMENAI_RETENTION_NOTIFY_ON_BLOCKED=true
LUMENAI_RETENTION_NOTIFY_ON_FAILURE=true
LUMENAI_RETENTION_NOTIFY_CHANNEL=slack
LUMENAI_APPROVAL_NOTIFICATIONS_ENABLED=true
LUMENAI_APPROVAL_NOTIFY_CHANNELS=slack,email
LUMENAI_APPROVAL_ESCALATION_HOURS=24
LUMENAI_APPROVAL_SLACK_CHANNEL=#governance-approvals
LUMENAI_APPROVAL_EMAILS=approver1@domain.com,approver2@domain.com
LUMENAI_DUNNING_AUTOMATION_ENABLED=true
LUMENAI_DUNNING_CHECK_CRON=0 */6 * * *
LUMENAI_DUNNING_NOTIFY_CHANNELS=slack,email
LUMENAI_DUNNING_RECOVERY_ACTIONS_ENABLED=true
LUMENAI_DUNNING_GRACE_DAYS=7
LUMENAI_GOVERNANCE_SLA_SCANNER_ENABLED=true
LUMENAI_GOVERNANCE_SLA_SCANNER_CRON=0 */6 * * *
